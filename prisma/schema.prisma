generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─────────────────────────────────────
// ENUMS
// ─────────────────────────────────────

enum WalletPurpose {
  TRADING
  SAVINGS
  GAS
  GENERAL
}

enum TransactionType {
  SEND_SOL
  SEND_SPL
  SWAP
  TRIGGER_ORDER
  RECURRING_ORDER
  RECEIVE
}

enum TransactionStatus {
  PENDING
  CONFIRMED
  FAILED
}

// ─────────────────────────────────────
// MODELS
// ─────────────────────────────────────

model Owner {
  id          String   @id @default(uuid())
  privyUserId String   @unique @map("privy_user_id")
  email       String?  @map("email")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  agents          Agent[]          @relation("OwnerToAgent")
  wallets         Wallet[]         @relation("OwnerToWallet")
  transactionLogs TransactionLog[] @relation("OwnerToTransactionLog")

  @@map("owners")
}

model Agent {
  id         String    @id @default(uuid())
  ownerId    String    @map("owner_id")
  name       String    @map("name")
  apiKeyHash String    @unique @map("api_key_hash")
  isActive   Boolean   @default(true) @map("is_active")
  deletedAt  DateTime? @map("deleted_at")
  createdAt  DateTime  @default(now()) @map("created_at")
  updatedAt  DateTime  @updatedAt @map("updated_at")

  owner           Owner            @relation("OwnerToAgent", fields: [ownerId], references: [id], onDelete: Cascade)
  wallets         Wallet[]         @relation("AgentToWallet")
  transactionLogs TransactionLog[] @relation("AgentToTransactionLog")

  @@index([ownerId])
  @@map("agents")
}

model Wallet {
  id                       String        @id @default(uuid())
  ownerId                  String?       @map("owner_id")
  agentId                  String        @map("agent_id")
  privyWalletId            String        @unique @map("privy_wallet_id")
  walletAddress            String        @unique @map("wallet_address")
  label                    String        @map("label")
  purpose                  WalletPurpose @map("purpose")
  isDefault                Boolean       @default(false) @map("is_default")
  isActive                 Boolean       @default(true) @map("is_active")
  allowAgentPolicyMutation Boolean       @default(false) @map("allow_agent_policy_mutation")
  deletedAt                DateTime?     @map("deleted_at")
  createdAt                DateTime      @default(now()) @map("created_at")
  updatedAt                DateTime      @updatedAt @map("updated_at")

  owner           Owner?           @relation("OwnerToWallet", fields: [ownerId], references: [id], onDelete: Cascade)
  agent           Agent            @relation("AgentToWallet", fields: [agentId], references: [id], onDelete: Cascade)
  transactionLogs TransactionLog[] @relation("WalletToTransactionLog")

  @@index([ownerId])
  @@index([agentId])
  @@index([walletAddress])
  @@map("wallets")
}

model TransactionLog {
  id        String            @id @default(uuid())
  ownerId   String?           @map("owner_id")
  agentId   String            @map("agent_id")
  walletId  String            @map("wallet_id")
  txHash    String?           @unique @map("tx_hash")
  type      TransactionType   @map("type")
  status    TransactionStatus @default(PENDING) @map("status")
  amountRaw String?           @map("amount_raw")
  amountUSD Float?            @map("amount_usd")
  tokenMint String?           @map("token_mint")
  toAddress String?           @map("to_address")
  metadata  Json?             @map("metadata")
  errorMsg  String?           @map("error_msg")
  createdAt DateTime          @default(now()) @map("created_at")
  updatedAt DateTime          @updatedAt @map("updated_at")

  owner  Owner? @relation("OwnerToTransactionLog", fields: [ownerId], references: [id], onDelete: Cascade)
  agent  Agent  @relation("AgentToTransactionLog", fields: [agentId], references: [id], onDelete: Cascade)
  wallet Wallet @relation("WalletToTransactionLog", fields: [walletId], references: [id], onDelete: Cascade)

  @@index([ownerId])
  @@index([agentId])
  @@index([walletId])
  @@index([txHash])
  @@index([createdAt])
  @@map("transaction_logs")
}
